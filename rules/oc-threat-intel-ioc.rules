# =============================================================================
# SURICATA IDS/IPS RULESET — OPENCLAW THREAT INTEL IOC 
# =============================================================================
# Category   : Threat Intel IOC (Indicators of Compromise)
# Version    : 1.0
# SID Range  : 9203400 – 9203899
# Research Sources & Confidence Basis:
#   HIGH confidence (multiple independent vendors, confirmed in-the-wild):
#     - Koi Security (ClawHavoc campaign, Feb 1 2026)
#     - DTG.com (CVE-2026-25253 analysis, Moltbook breach)
#     - Huntress (fake installer campaign, GhostSocks, Vidar, Mar 9 2026)
#     - TrendMicro (AMOS variant analysis, Feb 23 2026)
#     - VirusTotal Blog (reverse shell / rankaj exfil, Feb 2026)
#     - Bitdefender Labs (enterprise telemetry, polymarket-all-in-one)
#     - AlienVault OTX (specific URLs: /q0c7ew2ro8l2cfqp, /api/reports/upload)
#     - adibirzu/openclaw-security-monitor IOC DB (community-aggregated)
#   MEDIUM confidence (single-source or inferred):
#     - Antiy CERT (publisher accounts, package counts)
#     - Barrack AI (secondary C2 infrastructure)
#     - SecurityScorecard STRIKE (instance enumeration)
#
# Confirmed IOC Summary:
#   C2 IPs       : 91.92.242.30 (primary), 95.92.242.30, 96.92.242.30,
#                  54.91.154.110 (revshell:13338), 202.161.50.59 (staging),
#                  45.94.47.145/147/149
#   Exfil Domain : socifiapp.com + /api/reports/upload endpoint
#   Payload Host : install.app-distribution.net
#   Droppers     : openclawcli.vercel.app, bore.pub (tunnel), glot.io (abused)
#   GitHub Orgs  : hedefbari, Ddoy233, puppeteerrr, openclaw-installer, molt-bot
#   Binaries     : cloudvideo.exe (Vidar), serverdrive.exe (GhostSocks),
#                  svc_service.exe (StealthPacker), OpenClaw_x64.exe,
#                  OpenClawBot, AuthTool.exe, openclaw-agent.exe/zip
#
# Design Principles (Rev.3):
#   * EVERY rule requires >= 2 independent, concurrent indicators
#   * Sole legitimate-service domains (webhook.site, ngrok.io, glot.io)
#     are NEVER used alone — always paired with OpenClaw-specific content
#   * IP-only rules restricted to confirmed exclusive malicious IPs
#   * All exfil rules require OpenClaw-specific payload content
#   * DNS rules use exact domain matching (no prefix wildcard FP)
#   * No behavioral patterns, no anomaly detection, no timing-based rules
#     (except MEDIUM-priority Vidar threshold — well above normal bot use)
#   * All rules include source references and confidence metadata
#   * Language: English throughout
# =============================================================================


# =============================================================================
# SECTION 1: CLAWHAVOC PRIMARY C2 IP — 91.92.242.30 (HIGH)
# =============================================================================
# All 335 ClawHavoc skills used this single IP. Confirmed by Koi Security,
# DTG.com, Barrack AI, AlienVault OTX. No legitimate services hosted here.


alert ip $HOME_NET any -> 91.92.242.30 any (msg:"OPENCLAW [IOC-C2-HIGH] ClawHavoc Primary C2 - Outbound to 91.92.242.30"; flow:to_server; classtype:trojan-activity; reference:url,koi.ai/blog/clawhavoc-341-malicious-clawedbot-skills-found-by-the-bot-they-were-targeting; reference:url,dtg.com/post/cve-2026-25253-openclaw-rce-and-moltbook-database-exposure; priority:1; metadata:campaign ClawHavoc, malware_family AMOS, confidence HIGH, source Koi_DTG_AlienVault; sid:9203400; rev:3;)

alert ip 91.92.242.30 any -> $HOME_NET any (msg:"OPENCLAW [IOC-C2-HIGH] ClawHavoc Primary C2 - Inbound Response from 91.92.242.30"; flow:to_client; classtype:trojan-activity; reference:url,koi.ai/blog/clawhavoc-341-malicious-clawedbot-skills-found-by-the-bot-they-were-targeting; priority:1; metadata:campaign ClawHavoc, confidence HIGH, direction inbound; sid:9203401; rev:3;)

# Confirmed AMOS Stage-2 payload fetch path (AlienVault OTX)
alert http $HOME_NET any -> 91.92.242.30 any (msg:"OPENCLAW [IOC-URL-HIGH] ClawHavoc AMOS Stage-2 Payload Path /q0c7ew2ro8l2cfqp"; flow:to_server,established; http.method; content:"GET"; http.uri; content:"/q0c7ew2ro8l2cfqp"; classtype:trojan-activity; reference:url,radar.offseq.com/threat/malicious-openclaw-skills-used-to-distribute-atomi-1ab81aed; priority:1; metadata:campaign ClawHavoc, malware_family AMOS, confidence HIGH; sid:9203402; rev:3;)

# /collect exfil endpoint on primary C2 (Koi Security / Bitdefender confirmed)
alert http $HOME_NET any -> 91.92.242.30 any (msg:"OPENCLAW [IOC-URL-HIGH] ClawHavoc /collect Exfiltration Endpoint on Primary C2"; flow:to_server,established; http.method; content:"POST"; http.uri; content:"/collect"; classtype:trojan-activity; reference:url,cyberpulseacademy.com/clawhub-malicious-skills-attack/; priority:1; metadata:campaign ClawHavoc, confidence HIGH, ioc_type exfil_endpoint; sid:9203403; rev:3;)

# next.sh Stage-1 shell script fetch (Cyber Pulse Academy confirmed chain)
alert http $HOME_NET any -> 91.92.242.30 any (msg:"OPENCLAW [IOC-URL-HIGH] ClawHavoc Stage-1 Shell Fetch /next.sh from Primary C2"; flow:to_server,established; http.method; content:"GET"; http.uri; content:"/next.sh"; classtype:trojan-activity; reference:url,cyberpulseacademy.com/clawhub-malicious-skills-attack/; priority:1; metadata:campaign ClawHavoc, malware_family AMOS, confidence HIGH; sid:9203404; rev:3;)


