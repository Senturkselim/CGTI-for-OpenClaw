# =============================================================================
# SECTION 10: glot.io — STAGE-1 SCRIPT HOST (HIGH, specific URI required)
# =============================================================================
# Abused by ClawHavoc for base64-obfuscated macOS dropper scripts.
# Rule fires only on GET requests to /snippets/ or /raw/ paths.
# Legitimate developers rarely fetch raw snippets from glot.io in production flows.

alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"OPENCLAW [IOC-DOMAIN-HIGH] glot.io Shell Script Download - ClawHavoc Stage-1 Dropper (snippets/raw path)"; flow:to_server,established; http.host; content:"glot.io"; nocase; http.method; content:"GET"; http.uri; pcre:"/\/(snippets|raw)\/[a-z0-9]+/i"; classtype:trojan-activity; reference:url,koi.ai/blog/clawhavoc-341-malicious-clawedbot-skills-found-by-the-bot-they-were-targeting; priority:1; metadata:campaign ClawHavoc, confidence HIGH; sid:9203440; rev:3;)

alert dns $HOME_NET any -> any 53 (msg:"OPENCLAW [IOC-DNS-MED] DNS Query - glot.io (ClawHavoc Stage-1 Script Host, abused legitimate service)"; dns.query; content:"glot.io"; nocase; classtype:trojan-activity; reference:url,insiderllm.com/guides/openclaw-clawhub-security-alert/; priority:2; metadata:campaign ClawHavoc, confidence MEDIUM, note low_priority_standalone; sid:9203441; rev:3;)


# =============================================================================
# SECTION 11: AMOS macOS STEALER — OPENCLAW-SPECIFIC FILE EXFIL (HIGH)
