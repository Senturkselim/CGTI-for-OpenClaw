# ============================================================================

# --- Generic Stealer Panel: /gate.php Endpoint ---
# Many stealer families (Raccoon, Vidar variants) use /gate.php C2 endpoint
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"CGTI-OC STEALER - C2 Gate Endpoint POST (gate.php)"; flow:established,to_server; http.method; content:"POST"; http.uri; content:"/gate.php"; classtype:trojan-activity; priority:2; metadata:malware_family Generic_Stealer, mitre_attack T1041, signature_severity Major, false_positive Low; sid:9200100; rev:1;)

# --- Stealer Panel: /collect or /upload Endpoint ---
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"CGTI-OC STEALER - C2 Collect Endpoint POST"; flow:established,to_server; http.method; content:"POST"; http.uri; content:"/collect"; http.header; content:"multipart/form-data"; classtype:trojan-activity; priority:2; metadata:malware_family Generic_Stealer, mitre_attack T1041, signature_severity Major, false_positive Low; sid:9200101; rev:1;)

# --- Stealer: Sysinfo.txt in POST Body ---
