alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"CGTI-OC STEALER - Python UA Data Exfiltration POST"; flow:established,to_server; http.method; content:"POST"; http.user_agent; content:"python-requests"; http.header; content:"multipart/form-data"; classtype:trojan-activity; priority:2; metadata:malware_family PXA_Stealer, mitre_attack T1041, signature_severity Major, false_positive Low; sid:9200103; rev:1;)

# --- Stealer: FileGrabber in POST Body ---
