# ── 01L: GhostClaw/GhostLoader RAT (JFrog, March 2026) ─────────────────────
# npm package @openclaw-ai/openclawai deploys GhostLoader — a multi-stage
# infostealer+RAT that steals credentials, crypto wallets, SSH keys, browser
# data, Apple Keychain, and establishes persistent C2 with SOCKS5 proxy.
# Source: JFrog Security Research — "GhostClaw Unmasked" (8 Mar 2026)
# C2: trackpipe[.]dev (payload download + data exfiltration)
# Exfil: gofile.io (large archives), Telegram Bot API (small archives)

# GhostClaw TLS connection to C2 panel
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"CGTI-OC GHOSTCLAW - TLS Connection to trackpipe.dev C2 Panel (GhostLoader RAT)"; flow:to_server,established; tls.sni; content:"trackpipe.dev"; nocase; isdataat:!1,relative; classtype:trojan-activity; priority:1; reference:url,research.jfrog.com/post/ghostclaw-unmasked/; sid:9200124; rev:1; metadata:malware_family GhostClaw, mitre_attack T1071.001, signature_severity Critical, false_positive Zero, created_at 2026_03_17;)

# GhostClaw HTTP beacon/exfil to C2 panel
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"CGTI-OC GHOSTCLAW - HTTP Upload to trackpipe.dev (GhostLoader Data Exfiltration)"; flow:established,to_server; http.host; content:"trackpipe.dev"; nocase; classtype:trojan-activity; priority:1; reference:url,research.jfrog.com/post/ghostclaw-unmasked/; sid:9200125; rev:1; metadata:malware_family GhostClaw, mitre_attack T1041, signature_severity Critical, false_positive Zero, created_at 2026_03_17;)

# GhostClaw bootstrap payload request (specific URI pattern)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"CGTI-OC GHOSTCLAW - Bootstrap Payload Request to trackpipe.dev/t/bootstrap"; flow:established,to_server; http.host; content:"trackpipe.dev"; http.uri; content:"/t/bootstrap"; classtype:trojan-activity; priority:1; reference:url,research.jfrog.com/post/ghostclaw-unmasked/; sid:9200126; rev:1; metadata:malware_family GhostClaw, mitre_attack T1105, signature_severity Critical, false_positive Zero, created_at 2026_03_17;)

# GhostClaw fake npm package install detection
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"CGTI-OC GHOSTCLAW - Malicious npm Package @openclaw-ai/openclawai Download"; flow:established,to_server; http.host; content:"registry.npmjs.org"; http.uri; content:"openclaw-ai"; content:"openclawai"; distance:0; within:30; classtype:trojan-activity; priority:1; reference:url,research.jfrog.com/post/ghostclaw-unmasked/; sid:9200127; rev:1; metadata:malware_family GhostClaw, mitre_attack T1195.002, signature_severity Critical, false_positive Zero, created_at 2026_03_17;)

# GhostClaw GoFile.io large archive exfiltration with password locking
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"CGTI-OC GHOSTCLAW - GoFile.io Archive Upload (GhostLoader Bulk Exfil)"; flow:established,to_server; http.host; content:"gofile.io"; http.method; content:"POST"; http.content_type; content:"multipart/form-data"; classtype:trojan-activity; priority:1; reference:url,research.jfrog.com/post/ghostclaw-unmasked/; sid:9200128; rev:1; metadata:malware_family GhostClaw, mitre_attack T1041, signature_severity Critical, false_positive Low, created_at 2026_03_17;)


