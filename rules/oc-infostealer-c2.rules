# ============================================================================
# 01H: STEALER C2 BEACON — BEHAVIORAL PATTERNS
# ============================================================================
# Common C2 beacon behaviors across infostealer families.
# These rules carry higher FP risk and are managed via thresholds.
# ============================================================================

# --- IP Lookup Service (Reconnaissance) ---
# Stealers use services like ipinfo/ipapi to learn victim's IP
# Source: Redline, Vidar, AMOS common behavior
alert dns $HOME_NET any -> any any (msg:"CGTI-OC STEALER - IP Lookup Service DNS Query (api.ip.sb)"; dns.query; content:"api.ip.sb"; nocase; classtype:trojan-activity; priority:3; metadata:malware_family Generic_Stealer, mitre_attack T1016, signature_severity Informational, false_positive Medium, deployment_note May trigger on legitimate IP lookup - correlate with other stealer indicators; sid:9200090; rev:1;)

alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"CGTI-OC STEALER - IP Geolocation API via Non-Browser UA"; flow:established,to_server; http.host; content:"ipinfo.io"; http.user_agent; content:!"Mozilla"; classtype:trojan-activity; priority:3; metadata:malware_family Generic_Stealer, mitre_attack T1016, signature_severity Informational, false_positive Medium; sid:9200091; rev:1;)

alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"CGTI-OC STEALER - IP API Lookup via Non-Browser UA"; flow:established,to_server; http.host; content:"ip-api.com"; http.user_agent; content:!"Mozilla"; classtype:trojan-activity; priority:3; metadata:malware_family Generic_Stealer, mitre_attack T1016, signature_severity Informational, false_positive Medium; sid:9200092; rev:1;)

# --- Browser Database File Content in POST ---
# Detection of Chrome/Firefox/Safari cookie/password database content in POST body
# SQLite header: "SQLite format 3" (0x53 51 4c 69 74 65 20 66 6f 72 6d 61 74 20 33)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"CGTI-OC STEALER - SQLite Database in HTTP POST Body"; flow:established,to_server; http.method; content:"POST"; http.request_body; content:"SQLite format 3"; depth:20; classtype:trojan-activity; priority:1; metadata:malware_family Generic_Stealer, mitre_attack T1555.003, signature_severity Critical, false_positive Very_Low, deployment_note SQLite DB in POST body is strong stealer indicator; sid:9200093; rev:1;)

# --- Crypto Wallet Seed Phrase Pattern ---
# Detection of 12/24 word seed phrase (BIP39) exfiltration
# Seed phrase format: space-separated lowercase words
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"CGTI-OC STEALER - Potential Crypto Seed Phrase Exfiltration"; flow:established,to_server; http.method; content:"POST"; http.request_body; pcre:"/\b(abandon|ability|able|about|above|absent|absorb|abstract|absurd|abuse|access|accident|account|accuse|achieve|acid|acoustic|acquire|across|act|action|adapt|add|addict|address|adjust|admit|adult|advance|advice|aerobic|affair|afford|afraid|again|age|agent|agree|ahead|aim|air|airport|aisle|alarm|album|alcohol|alert|alien|all|alley|allow|almost|alone)\b.{1,200}\b(abandon|ability|able|about|above|absent|absorb|abstract|absurd|abuse|access|accident|account|accuse|achieve|acid|acoustic|acquire|across|act|action|adapt|add|addict|address|adjust|admit|adult|advance|advice|aerobic|affair|afford|afraid|again|age|agent|agree|ahead|aim|air|airport|aisle|alarm|album|alcohol|alert|alien|all|alley|allow|almost|alone)\b/i"; classtype:trojan-activity; priority:1; metadata:malware_family Generic_Stealer, mitre_attack T1552, signature_severity Critical, false_positive Very_Low, deployment_note BIP39 seed words in POST body; sid:9200094; rev:1;)


